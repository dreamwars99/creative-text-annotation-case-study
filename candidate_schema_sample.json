{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Creative Text Annotation Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidateId",
    "factorId",
    "subelementId",
    "candidate",
    "evidence",
    "provenance",
    "reviewState"
  ],
  "properties": {
    "candidateId": {
      "type": "string",
      "description": "Stable candidate identifier."
    },
    "factorId": {
      "type": "string",
      "enum": ["concept"]
    },
    "subelementId": {
      "type": "string",
      "enum": [
        "concept.core_premise",
        "concept.narrative_question",
        "concept.logline"
      ]
    },
    "candidate": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "quote"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["user_seed", "draft_text", "review_note"]
          },
          "quote": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "reason": {
            "type": "string",
            "maxLength": 300
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["human_reviewer", "demo_extractor", "model_candidate"]
        },
        "modelName": {
          "type": "string",
          "description": "Optional. Excluded when not relevant."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "reviewState": {
      "type": "string",
      "enum": [
        "needs_human_review",
        "applied",
        "edited",
        "rejected",
        "locked"
      ]
    }
  },
  "examples": [
    {
      "candidateId": "concept.core_premise.sample.001",
      "factorId": "concept",
      "subelementId": "concept.core_premise",
      "candidate": "A created life can force its creator to face the moral cost of creation.",
      "confidence": 0.82,
      "evidence": [
        {
          "source": "user_seed",
          "quote": "A created life asks its creator to take responsibility.",
          "reason": "The quote directly states a creator-created responsibility conflict."
        }
      ],
      "provenance": {
        "sourceType": "demo_extractor",
        "createdAt": "2026-05-28T00:00:00Z"
      },
      "reviewState": "needs_human_review"
    }
  ]
}
